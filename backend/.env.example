# --- Telegram ---
# @BotFather'dan olingan YANGI token (eskisini /revoke qiling!)
BOT_TOKEN=your_telegram_bot_token_here

# --- Database (Railway PostgreSQL "Connect" bo'limidan) ---
DATABASE_URL=postgresql://user:password@host:5432/railway

# --- AI Matching (Anthropic Claude) ---
# https://console.anthropic.com/ dan oling. Bo'sh qoldirilsa lokal matching ishlatiladi.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Biznes sozlamalari ---
# 1 USD necha so'm (farqni $ da ko'rsatish uchun).
USD_RATE=12600

# Moslik chegarasi (0..1). Faqat AI o'chirilganda ishlatiladi.
MATCH_THRESHOLD=0.6
